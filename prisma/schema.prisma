generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type      String?
  scope             String?
  id_token        String? @db.Text
  session_state   String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  vitals        Vital[]
  medications   Medication[]
  workouts      Workout[]
  moods         Mood[]
  sleepLogs     Sleep[]
  nutrition     Nutrition[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Vital {
  id          String   @id @default(cuid())
  userId      String
  bloodPressureSystolic   Int?
  bloodPressureDiastolic  Int?
  heartRate   Int?
  temperature Float?
  spO2        Int?
  timestamp   DateTime @default(now())
  notes       String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp])
}

model Medication {
  id        String   @id @default(cuid())
  userId    String
  name      String
  dosage    String
  time      DateTime
  taken     Boolean  @default(false)
  timestamp DateTime @default(now())
  notes     String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp])
}

model Workout {
  id        String   @id @default(cuid())
  userId    String
  type      String
  duration  Int
  calories  Int?
  intensity String?
  timestamp DateTime @default(now())
  notes     String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp])
}

model Mood {
  id        String   @id @default(cuid())
  userId    String
  rating    Int
  notes     String?
  tags      String[]
  timestamp DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp])
}

model Sleep {
  id          String   @id @default(cuid())
  userId      String
  bedtime     DateTime
  wakeTime    DateTime
  quality     Int
  notes       String?
  timestamp   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp])
}

model Nutrition {
  id        String   @id @default(cuid())
  userId    String
  meal      String
  calories  Int?
  protein   Float?
  carbs     Float?
  fats      Float?
  timestamp DateTime @default(now())
  notes     String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp])
}
