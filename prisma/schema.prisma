// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url removed — handled in prisma.config.ts
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  entries   HealthEntry[]
}

model HealthEntry {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      DateTime
  weight    Float?
  sleep     Float?
  calories  Int?
  steps     Int?
  mood      Int?
  notes     String?
  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
}
